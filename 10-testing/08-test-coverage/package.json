{
  "name": "08-test-coverage",
  "version": "1.0.0",
  "description": "This sample showcases how to collect and visualize test coverage",
  "type": "module",
  "scripts": {
    "test": "node --test --experimental-test-coverage",
    "test:lcov": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info",
    "lint": "biome check --no-errors-on-unmatched",
    "lint:fix": "biome check --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "engineStrict": true,
  "keywords": [],
  "author": "Luciano Mammino and Mario Casciaro",
  "license": "MIT",
  "devDependencies": {
    "@lcov-viewer/cli": "^1.3.0",
    "c8": "^10.1.3"
  }
}
