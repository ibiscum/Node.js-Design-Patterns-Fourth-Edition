{
  "name": "09-test-with-typescript",
  "version": "1.0.0",
  "description": "This sample showcases how to test using TypeScript",
  "type": "module",
  "scripts": {
    "test": "node --test --experimental-test-coverage --test-coverage-exclude='**/coverage/**' '**/*.test.ts'",
    "test:lcov": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info",
    "lint": "biome check --no-errors-on-unmatched",
    "lint:fix": "biome check --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "engineStrict": true,
  "keywords": [],
  "author": "Luciano Mammino and Mario Casciaro",
  "license": "MIT",
  "devDependencies": {
    "@lcov-viewer/cli": "^1.3.0",
    "c8": "^11.0.0",
    "typescript": "^5.9.3"
  }
}
