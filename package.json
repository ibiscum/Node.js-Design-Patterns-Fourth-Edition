{
  "name": "node-js-design-patterns-fourth-edition",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Code samples for the book Node.js Design Patterns, 4th Edition by Mario Casciaro and Luciano Mammino",
  "scripts": {
    "test": "pnpm run test:lint",
    "test:lint": "biome check --no-errors-on-unmatched",
    "test:lint-fix": "biome check --fix",
    "prepare": "husky"
  },
  "keywords": [
    "node.js",
    "design patterns",
    "book",
    "code samples"
  ],
  "author": "Luciano Mammino and Mario Casciaro",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@tootallnate/once": "^3.0.1",
    "mkdirp": "^3.0.1",
    "tar": "^7.5.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@tootallnate/once": ">=3.0.1",
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tar": ">=7.5.11"
  },
  "lint-staged": {
    "*": [
      "pnpm run test:lint"
    ]
  }
}
